{
    "name": "vusys/laravel-smarty",
    "description": "Replace Blade with Smarty as the default Laravel template engine.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^10.0|^11.0|^12.0|^13.0",
        "smarty/smarty": "^5.4"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.0",
        "larastan/larastan": "^2.9 || ^3.0",
        "laravel/pennant": "^1.0|^2.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Vusys\\LaravelSmarty\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vusys\\LaravelSmarty\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vusys\\LaravelSmarty\\SmartyServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "analyze": "@analyse",
        "rector": "rector process",
        "rector:check": "rector process --dry-run",
        "pint": "pint",
        "pint:check": "pint --test",
        "test": "phpunit",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-text",
        "test:coverage-html": "XDEBUG_MODE=coverage phpunit --coverage-html=build/coverage"
    }
}
