{
    "name": "vusys/laravel-smarty",
    "description": "Replace Blade with Smarty as the default Laravel template engine.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "smarty",
        "template",
        "templating",
        "view",
        "blade",
        "template-engine"
    ],
    "homepage": "https://vusys.github.io/laravel-smarty/",
    "authors": [
        {
            "name": "Bryan",
            "email": "bryan@vuii.co.uk"
        }
    ],
    "support": {
        "issues": "https://github.com/Vusys/laravel-smarty/issues",
        "source": "https://github.com/Vusys/laravel-smarty",
        "docs": "https://vusys.github.io/laravel-smarty/"
    },
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^10.0|^11.0|^12.0|^13.0",
        "smarty/smarty": "^5.4"
    },
    "suggest": {
        "laravel/pennant": "Required for the {feature} block and the feature_active modifier"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.0",
        "infection/infection": "^0.33",
        "larastan/larastan": "^2.9 || ^3.0",
        "laravel/pennant": "^1.0|^2.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Vusys\\LaravelSmarty\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vusys\\LaravelSmarty\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vusys\\LaravelSmarty\\SmartyServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "analyze": "@analyse",
        "rector": "rector process",
        "rector:check": "rector process --dry-run",
        "pint": "pint",
        "pint:check": "pint --test",
        "test": "phpunit",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-text",
        "test:coverage-html": "XDEBUG_MODE=coverage phpunit --coverage-html=build/coverage",
        "infection": "infection --threads=max"
    }
}
