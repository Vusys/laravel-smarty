{
    "name": "vusys/laravel-smarty",
    "description": "Replace Blade with Smarty as the default Laravel template engine.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/view": "^11.0|^12.0|^13.0",
        "smarty/smarty": "^5.4"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Vusys\\LaravelSmarty\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vusys\\LaravelSmarty\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vusys\\LaravelSmarty\\SmartyServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
